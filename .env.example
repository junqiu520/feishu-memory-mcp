FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=   # get from Feishu developer console
AGENT_ID=default
MEMORY_BITABLE_APP_TOKEN=bascnxxxxxxxxxxxxxx
MEMORY_BITABLE_TABLE_ID=tblxxxxxxxxxxxxxx
KNOWLEDGE_BITABLE_APP_TOKEN=bascnyyyyyyyyyyyy
KNOWLEDGE_BITABLE_TABLE_ID=tblyyyyyyyyyyyy
